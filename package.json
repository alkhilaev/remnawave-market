{
  "name": "remnawave-market",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1"
  },
  "lint-staged": {
    "backend/src/**/*.ts": [
      "bash -c 'cd backend && npx eslint --fix \"$@\"' _",
      "bash -c 'cd backend && npx prettier --write \"$@\"' _"
    ],
    "bot/src/**/*.ts": [
      "bash -c 'cd bot && npx eslint --fix \"$@\"' _",
      "bash -c 'cd bot && npx prettier --write \"$@\"' _"
    ],
    "frontend/**/*.{ts,vue}": [
      "bash -c 'cd frontend && npx eslint --fix \"$@\"' _",
      "bash -c 'cd frontend && npx prettier --write \"$@\"' _"
    ]
  }
}
